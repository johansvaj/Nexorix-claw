# modules/webui.py
import threading
from fastapi import FastAPI, WebSocket, WebSocketDisconnect
from fastapi.responses import HTMLResponse
import uvicorn

class WebUI:
    def __init__(self, message_bus=None, port=18888):
        self.port = port
        self.bus = message_bus
        self.app = FastAPI(title="Nexcorix Claw WebUI")
        self._server_thread = None
        self.active_connections = []
        self._setup_routes()

    def _setup_routes(self):
        @self.app.get("/")
        async def root():
            html_content = """<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexcorix Claw · AI Agent</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: radial-gradient(circle at 20% 30%, #0a0f1e, #03060c);
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .glass {
            width: 100%;
            max-width: 1000px;
            height: 85vh;
            background: rgba(18, 25, 45, 0.65);
            backdrop-filter: blur(14px);
            border-radius: 2rem;
            border: 1px solid rgba(59, 130, 246, 0.4);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(59,130,246,0.2);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .header {
            padding: 1rem 1.5rem;
            background: rgba(10, 15, 30, 0.7);
            border-bottom: 1px solid #2d3748;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .logo { font-size: 2rem; filter: drop-shadow(0 0 6px #8b5cf6); }
        .title {
            font-size: 1.4rem;
            font-weight: 600;
            background: linear-gradient(120deg, #a78bfa, #3b82f6);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
        }
        .badge {
            background: #1e293b;
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            color: #94a3b8;
            margin-left: auto;
            font-family: monospace;
        }
        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .message {
            max-width: 80%;
            animation: fadeIn 0.2s ease-out;
        }
        .user { align-self: flex-end; }
        .assistant { align-self: flex-start; }
        .bubble {
            padding: 0.75rem 1.25rem;
            border-radius: 1.5rem;
            background: #1e293b;
            color: #e2e8f0;
            word-wrap: break-word;
            line-height: 1.45;
            font-size: 0.95rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        .user .bubble {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: white;
            border-bottom-right-radius: 0.25rem;
        }
        .assistant .bubble {
            background: #0f172a;
            border-bottom-left-radius: 0.25rem;
            border-left: 3px solid #3b82f6;
        }
        .time {
            font-size: 0.65rem;
            margin-top: 0.3rem;
            margin-left: 0.8rem;
            color: #64748b;
        }
        .input-area {
            padding: 1rem 1.5rem 1.5rem;
            background: rgba(10, 15, 30, 0.7);
            border-top: 1px solid #2d3748;
            display: flex;
            gap: 0.75rem;
        }
        .input-area input {
            flex: 1;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 3rem;
            padding: 0.8rem 1.2rem;
            color: #f1f5f9;
            font-size: 0.95rem;
            outline: none;
            transition: all 0.2s;
        }
        .input-area input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.3);
        }
        .input-area button {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border: none;
            border-radius: 3rem;
            width: 48px;
            height: 48px;
            cursor: pointer;
            font-size: 1.3rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.1s;
        }
        .input-area button:hover { transform: scale(1.03); opacity: 0.9; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
